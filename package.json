{
  "name": "semilla-ecommerce",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev . --compatibility-flags=nodejs_compat",
    "deploy": "wrangler pages deploy .",
    "db:init": "wrangler d1 execute shop --file=./data/schema.sql",
    "db:init:local": "wrangler d1 execute shop --local --file=./data/schema.sql",
    "db:seed": "wrangler d1 execute shop --file=./data/seed.sql",
    "db:seed:local": "wrangler d1 execute shop --local --file=./data/seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "stripe": "^18.3.0"
  },
  "devDependencies": {
    "wrangler": "^3.95.0"
  }
}
