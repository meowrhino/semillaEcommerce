# Puerto local (en Render lo inyecta la plataforma)
PORT=3000

# URL pública del frontend (usada en Stripe success/cancel URLs)
FRONTEND_URL=http://127.0.0.1:5500

# Orígenes permitidos en CORS (coma-separado, soporta *.dominio)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://*.github.io

# Token para rutas /admin/*
ADMIN_TOKEN=cambiame

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Driver de persistencia: json | sqlite | turso
STORE_DRIVER=json

# Si STORE_DRIVER=json y quieres versionar cambios en GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Si STORE_DRIVER=turso
TURSO_URL=
TURSO_AUTH_TOKEN=
